{
  "name": "frontend-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx dotenvx run --env-file=.env.dev -- next dev -p 4001 --turbopack",
    "local": "npx dotenvx run --env-file=.env.local -- next dev -p 4001 --turbopack",
    "prod": "npx dotenvx run --env-file=.env.production -- next dev -p 4001 --turbopack",
    "build-prod": "npx dotenvx run --env-file=.env.production -- next build",
    "build-local": "npx dotenvx run --env-file=.env.local -- next build",
    "build-dev": "npx dotenvx run --env-file=.env.dev -- next build",
    "start": "npx dotenvx run --env-file=.env.production -- next start -p 4003",
    "start-local": "npx dotenvx run --env-file=.env.local -- next start -p 4001",
    "start-dev": "npx dotenvx run --env-file=.env.dev -- next start -p 4002",
    "lint": "next lint"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.44.1",
    "@reduxjs/toolkit": "^2.8.2",
    "axios": "^1.10.0",
    "chart.js": "^4.5.0",
    "dayjs": "^1.11.13",
    "framer-motion": "^12.23.24",
    "highlight.js": "^11.11.1",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "katex": "^0.16.22",
    "lucide-react": "^0.517.0",
    "next": "15.3.8",
    "plyr-react": "^5.3.0",
    "prop-types": "^15.8.1",
    "quill": "^2.0.3",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-player": "^3.3.1",
    "react-redux": "^9.2.0",
    "recharts": "^2.15.4",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "uuid": "^13.0.0",
    "video.js": "^8.22.0",
    "videojs-youtube": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "prettier": "3.5.3",
    "tailwindcss": "^4"
  }
}
